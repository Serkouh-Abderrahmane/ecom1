# ============================================================
# Nestoria frontend — environment variables
# Copy this file to `.env` and fill in real values.
# Vite only exposes variables prefixed with VITE_ to client code.
# ============================================================

# Base URL of the Nestoria API. Include the /api suffix.
VITE_API_URL=http://localhost:5000/api

# Google OAuth Client ID — must be the same one the backend uses to verify ID tokens.
# Get it from https://console.cloud.google.com/apis/credentials
# Leaving this blank disables the "Sign in with Google" button; email + password still works.
VITE_GOOGLE_CLIENT_ID=
